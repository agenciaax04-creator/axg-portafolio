---
import LogoMark from "@/components/LogoMark.astro";

interface Props {
  showHome?: boolean;
}

const { showHome = false } = Astro.props;

const NAV_LINKS = [
  ...(showHome ? [{ href: "/", label: "Inicio" }] : []),
  { href: "/servicios", label: "Servicios" },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/contacto", label: "Contacto" },
];
---

<header
  class="fixed top-0 inset-x-0 z-50 border-b border-white/5 bg-ax-void/70 backdrop-blur-md"
>
  <nav
    class="relative mx-auto max-w-7xl px-5 sm:px-8 h-16 sm:h-20 flex items-center justify-between gap-4"
    aria-label="Navegación principal"
  >
    <!-- Marca: isotipo oficial + wordmark -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Agencia AX - Inicio">
      <LogoMark class="h-11 w-11 sm:h-12 sm:w-12" imageClass="h-[120%] w-[120%]" />
      <span class="font-display tracking-tightest text-lg sm:text-xl font-semibold">
        Agencia <span class="text-ax-gold">AX</span>
      </span>
    </a>

    <!-- Enlaces (desktop) -->
    <ul class="hidden lg:flex items-center justify-center gap-8 absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
      {
        NAV_LINKS.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-sm text-white/75 hover:text-white transition-colors"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA -->
    <a
      href="/contacto"
      class="hidden lg:inline-flex items-center justify-center h-10 sm:h-11 px-4 sm:px-5 rounded-full text-sm font-medium bg-ax-gold text-ax-void hover:bg-ax-goldSoft shadow-goldGlow transition-colors"
    >
      Cotizar
    </a>

    <button type="button" id="mobile-menu-open" class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-white transition-colors hover:bg-white/[0.08] lg:hidden" aria-label="Abrir menú">
        <span class="sr-only">Abrir menú</span>
        <span class="flex flex-col gap-1.5">
          <span class="block h-0.5 w-5 rounded-full bg-white"></span>
          <span class="block h-0.5 w-5 rounded-full bg-white"></span>
          <span class="block h-0.5 w-5 rounded-full bg-white"></span>
        </span>
    </button>

    <div id="mobile-menu-overlay" class="fixed inset-0 z-[60] hidden bg-ax-void/40 backdrop-blur-md lg:hidden">
      <aside id="mobile-menu-panel" class="absolute right-0 top-0 h-full w-[82vw] max-w-sm overflow-hidden border-l border-white/10 bg-ax-void shadow-2xl">
        <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_25%_15%,rgba(213,159,15,0.18),transparent_28%),radial-gradient(circle_at_80%_35%,rgba(244,200,74,0.12),transparent_24%),linear-gradient(180deg,rgba(0,61,100,0.28),rgba(5,7,13,0.98))]"></div>
        <div class="flex items-center justify-between border-b border-white/10 p-5">
          <span class="font-display text-lg font-semibold">
            Agencia <span class="text-ax-gold">AX</span>
          </span>
          <button type="button" id="mobile-menu-close" class="grid h-10 w-10 place-items-center rounded-full border border-white/10 bg-white/[0.04] text-xl text-white" aria-label="Cerrar menú">
            ×
          </button>
        </div>
        <div class="grid gap-2 p-5">
        {
          NAV_LINKS.map((l) => (
            <a
              href={l.href}
              class="rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-4 text-base text-white/80 transition-colors hover:bg-white/[0.08] hover:text-white"
            >
              {l.label}
            </a>
          ))
        }
        </div>
      </aside>
    </div>
  </nav>
</header>

<script is:inline>
  const openButton = document.getElementById("mobile-menu-open");
  const closeButton = document.getElementById("mobile-menu-close");
  const overlay = document.getElementById("mobile-menu-overlay");
  const panel = document.getElementById("mobile-menu-panel");

  const openMenu = () => {
    overlay?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  };

  const closeMenu = () => {
    overlay?.classList.add("hidden");
    document.body.style.overflow = "";
  };

  openButton?.addEventListener("click", openMenu);
  closeButton?.addEventListener("click", closeMenu);
  overlay?.addEventListener("click", (event) => {
    if (event.target === overlay) closeMenu();
  });
  panel?.addEventListener("click", (event) => event.stopPropagation());
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeMenu();
  });
</script>
