---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import { projects } from "@/data/projects";
---

<Layout title="Proyectos | Agencia AX">
  <main class="relative min-h-screen pt-28 sm:pt-32 px-5 sm:px-8 pb-20">
    <Navbar showHome />

    <section class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.28em] text-ax-gold">Proyectos</p>
        <h1 class="mt-4 font-display text-4xl sm:text-6xl font-semibold tracking-tightest leading-tight">
          Galería visual para trabajos de alto impacto.
        </h1>
        <p class="mt-5 text-white/70 text-base sm:text-lg leading-relaxed">
          Espacios listos para capturas, mockups o previews de sitios web y aplicaciones creadas por Agencia AX.
        </p>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {projects.map((project) => (
          <a href={`/proyectos/${project.slug}`} class="group overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] transition-colors hover:border-ax-gold/45">
            <div class="aspect-[4/3] bg-ax-blue/45 ring-1 ring-inset ring-ax-gold/15 grid place-items-center">
              <span class="text-sm uppercase tracking-[0.25em] text-white/45">Caso</span>
            </div>
            <div class="p-5">
              <h2 class="font-display text-xl font-semibold text-white">{project.title}</h2>
              <p class="mt-2 text-sm text-white/60">{project.category}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
