// Esquema de base de datos AXG
// Documentación: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Proyecto {
  id          String   @id @default(cuid())
  titulo      String
  descripcion String
  imagen      String
  enlace      String
  destacado   Boolean  @default(false)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("proyectos")
}

model Prospecto {
  id        String   @id @default(cuid())
  nombre    String
  correo    String
  telefono  String?
  servicio  String?
  mensaje   String
  estado    String   @default("nuevo") // nuevo | contactado | cerrado
  createdAt DateTime @default(now())

  @@index([correo])
  @@map("prospectos")
}
